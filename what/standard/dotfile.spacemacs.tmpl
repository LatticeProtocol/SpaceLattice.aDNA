;; Vault: github.com/LatticeProtocol/SpaceLattice.aDNA  (planned Phase 7)

(defun dotspacemacs/layers ()
  "Configuration layers declaration."
  (setq-default
   dotspacemacs-distribution 'spacemacs
   dotspacemacs-enable-lazy-installation 'unused
   dotspacemacs-ask-for-lazy-installation t
   dotspacemacs-configuration-layer-path '({{LAYER_PATH_LIST}})
   dotspacemacs-configuration-layers
   '(
     ;; === editing & navigation ===
     auto-completion
     better-defaults
     helm
     (treemacs :variables treemacs-use-follow-mode t)
     git
     version-control
     ibuffer                                         ; grouped buffer list (C-x C-b)
     (tabs :variables tabs-group-by-project-name t) ; centaur-tabs — project-grouped tabs
     imenu-list                                      ; outline side panel (SPC b i)
     nav-flash                                       ; flash current line after navigation

     ;; === OS & fonts ===
     osx                                             ; macOS modifier keys + system integration
     unicode-fonts                                   ; color emoji + full Unicode coverage on macOS

     ;; === languages ===
     (lsp :variables lsp-headerline-breadcrumb-enable t)
     (python :variables python-backend 'lsp python-fill-column 100)
     (typescript :variables typescript-fmt-on-save t)
     (rust :variables rust-backend 'lsp rust-format-on-save t)
     (go :variables go-backend 'lsp go-format-before-save t)
     (javascript :variables javascript-backend 'lsp node-add-modules-path t)
     react                                           ; extends javascript layer
     shell-scripts
     emacs-lisp
     (markdown :variables markdown-live-preview-engine 'vmd)
     (org :variables org-want-todo-bindings t
                      org-enable-roam-support t)
     yaml
     csv
     toml
     graphviz                                        ; .dot file editing + live preview
     mermaid                                         ; .mmd diagrams (requires mermaid-cli)
     (latex :variables latex-build-command "LatexMk"
                       latex-backend 'lsp)           ; requires texlive + texlab LSP
     pdf                                             ; pdf-tools — native PDF rendering
     epub                                            ; nov.el — epub reader

     ;; === tools ===
     (shell :variables shell-default-shell 'vterm shell-default-position 'bottom)
     multiple-cursors
     spell-checking
     syntax-checking
     restclient                                      ; HTTP REPL via .http files (SPC m s s)
     docker                                          ; Dockerfile + docker-compose support
     (dap :variables dap-python-debugger 'debugpy)  ; Debug Adapter Protocol — all language debuggers
     tree-sitter                                     ; Emacs 29+ treesit — structured syntax highlighting

     ;; === AI + agentic ===
     claude-code                                     ; Claude Code CLI integration (official Spacemacs layer)
     (llm-client :variables llm-client-enable-gptel t) ; gptel — Claude/OpenAI/Ollama from any buffer

     ;; === SpaceLattice.aDNA bridge ===
     adna

     ;; === operator-added local layers (loaded by user-init from what/local/) ===
     {{LOCAL_LAYER_LIST}}
     )
   ;; Packages not in any layer:
   ;;   link-hint  — Vimium-style overlay on all visible links (SPC j o / SPC j O)
   ;;   ace-link   — 'o' in eww/info/help jumps to any visible link
   dotspacemacs-additional-packages '(link-hint ace-link)
   dotspacemacs-frozen-packages '()
   dotspacemacs-excluded-packages '()
   dotspacemacs-install-packages 'used-only))

(defun dotspacemacs/init ()
  "Initialization. Called at very startup, before layers, packages, or user config."
  (setq-default
   dotspacemacs-elpa-https t
   dotspacemacs-elpa-timeout 5
   dotspacemacs-check-for-update nil
   dotspacemacs-elpa-subdirectory 'emacs-version
   dotspacemacs-editing-style 'vim
   ;; Banner: 'official on 0.999.x rolling release — custom .txt path deferred to P4.
   dotspacemacs-startup-banner 'official
   dotspacemacs-startup-lists '((recents . 5) (projects . 7))
   dotspacemacs-startup-buffer-responsive t
   dotspacemacs-show-startup-list-numbers t
   ;; Stock spacemacs-dark theme — LP-consistent, no extra packages needed.
   ;; doom-modeline (below) adapts to this theme's faces automatically.
   dotspacemacs-themes '(spacemacs-dark spacemacs-light)
   ;; doom-modeline: superior info density + aDNA vault segment.
   ;; Adapts to spacemacs-dark faces (icon nil = text-only, theme-agnostic).
   dotspacemacs-mode-line-theme 'doom
   dotspacemacs-colorize-cursor-according-to-state t
   dotspacemacs-default-font '("Source Code Pro" :size 15.0 :weight normal :width normal)
   dotspacemacs-leader-key "SPC"
   dotspacemacs-emacs-command-key "SPC"
   dotspacemacs-ex-command-key ":"
   dotspacemacs-emacs-leader-key "M-m"
   dotspacemacs-major-mode-leader-key ","
   dotspacemacs-major-mode-emacs-leader-key "C-M-m"
   dotspacemacs-distinguish-gui-tab nil
   dotspacemacs-default-layout-name "Default"
   dotspacemacs-display-default-layout nil
   dotspacemacs-auto-resume-layouts nil
   dotspacemacs-auto-generate-layout-names nil
   dotspacemacs-large-file-size 1
   dotspacemacs-auto-save-file-location 'cache
   dotspacemacs-max-rollback-slots 5
   dotspacemacs-enable-paste-transient-state nil
   dotspacemacs-which-key-delay 0.4
   dotspacemacs-which-key-position 'bottom
   dotspacemacs-switch-to-buffer-prefers-purpose nil
   dotspacemacs-loading-progress-bar t
   dotspacemacs-fullscreen-at-startup nil
   dotspacemacs-fullscreen-use-non-native nil
   dotspacemacs-maximized-at-startup t
   dotspacemacs-undecorated-at-startup nil
   dotspacemacs-active-transparency 90
   dotspacemacs-inactive-transparency 90
   dotspacemacs-show-transient-state-title t
   dotspacemacs-show-transient-state-color-guide t
   dotspacemacs-mode-line-unicode-symbols t
   dotspacemacs-smooth-scrolling t
   dotspacemacs-line-numbers '(:relative t :enabled-for-modes prog-mode text-mode)
   dotspacemacs-folding-method 'evil
   dotspacemacs-smartparens-strict-mode nil
   dotspacemacs-smart-closing-parenthesis nil
   dotspacemacs-highlight-delimiters 'all
   dotspacemacs-enable-server t
   dotspacemacs-server-socket-dir nil
   dotspacemacs-persistent-server t
   dotspacemacs-search-tools '("rg" "ag" "grep")
   dotspacemacs-frame-title-format "%I@%S"
   dotspacemacs-icon-title-format nil
   dotspacemacs-show-trailing-whitespace t
   dotspacemacs-whitespace-cleanup 'trailing
   dotspacemacs-use-clean-aindent-mode t
   dotspacemacs-zone-out-when-idle nil
   dotspacemacs-pretty-docs nil
   dotspacemacs-home-shorten-agenda-source nil
   dotspacemacs-byte-compile nil))

(defun dotspacemacs/user-env ()
  "Setup environment variables."
  (spacemacs/load-spacemacs-env))

(defun dotspacemacs/user-init ()
  "Called before layer config. Sets pre-load preferences and pulls in operator-private elisp."
  ;; vterm: auto-compile the native module on first install (no interactive
  ;; prompt during batch boot). Required for skill_install to complete in
  ;; ref-clean envs where the module hasn't been compiled yet.
  (setq vterm-always-compile-module t)

  ;; Load operator's private elisp last (gitignored) — additive only.
  (let ((private-el (expand-file-name "operator.private.el"
                                      "{{LOCAL_LAYER_DIR}}")))
    (when (file-readable-p private-el)
      (load private-el nil 'nomessage))))

(defun dotspacemacs/user-load ()
  "Library to load when dumping. Empty for now.")

(defun dotspacemacs/user-config ()
  "Configuration. Called at end of startup, after layers loaded."
  ;; Changes in this function body: reload with SPC f e R (hot-reload, ~3s).
  ;; Changes in dotspacemacs/init, new layers, or new packages: SPC q r (full restart, ~20s).
  ;;
  ;; aDNA layer activation surface
  (when (fboundp 'adna/setup-global-hooks)
    (adna/setup-global-hooks))

  ;; Lattice workspace root — all finds, terminals, and projects anchor here
  (cd (expand-file-name "~/lattice/"))

  ;; Project-search prefers ripgrep; discover all vaults in ~/lattice/
  (with-eval-after-load 'projectile
    (setq projectile-generic-command "rg --files --hidden --glob '!.git/'")
    (setq projectile-project-search-path (list (expand-file-name "~/lattice/")))
    (projectile-discover-projects-in-search-path))

  ;; ── treemacs: ~/lattice/ as default workspace ────────────────────────────
  (with-eval-after-load 'treemacs
    (let ((lattice (expand-file-name "~/lattice")))
      (when (and (file-directory-p lattice)
                 (fboundp 'treemacs-add-project-to-workspace))
        (treemacs-add-project-to-workspace lattice "Lattice"))))

  ;; Magit performance
  (with-eval-after-load 'magit
    (setq magit-refresh-status-buffer nil))

  ;; ── Jump navigation (Vimium-style) ──────────────────────────────────────
  ;; avy-goto-char-timer: type any sequence → 0.5s pause → decision tree
  ;; This is the closest Emacs equivalent to Vimium's link-following overlay.
  (with-eval-after-load 'avy
    (setq avy-timeout-seconds 0.3))         ; snappier than default 0.5
  ;; Remap SPC j J to char-timer (more Vimium-like than default char-2)
  (spacemacs/set-leader-keys "jJ" #'avy-goto-char-timer)

  ;; link-hint: Vimium-style overlay on all visible links in any buffer
  (with-eval-after-load 'link-hint
    (spacemacs/set-leader-keys "jo" #'link-hint-open-link)
    (spacemacs/set-leader-keys "jO" #'link-hint-copy-link))

  ;; ── eww browser ─────────────────────────────────────────────────────────
  ;; SpaceLattice browser stack:
  ;;   eww         — text-heavy pages, docs, programmatic URL fetch
  ;;   xwidget     — JS pages when Emacs compiled --with-xwidgets
  ;;   external    — complex web apps (override per-buffer with & in eww)
  (with-eval-after-load 'eww
    ;; ace-link: press 'o' in eww to overlay letters on all visible links
    (when (fboundp 'ace-link-eww)
      (define-key eww-mode-map (kbd "o") #'ace-link-eww))
    ;; v in eww opens current URL in external browser
    (define-key eww-mode-map (kbd "v") #'eww-open-in-new-buffer))

  ;; Route URLs: docs/GitHub → eww; auth/SPA → external browser
  (setq browse-url-browser-function
        '((".*claude\\.ai.*"            . browse-url-default-browser)
          (".*atlassian\\.net.*"        . browse-url-default-browser)
          (".*slack\\.com.*"            . browse-url-default-browser)
          (".*"                         . eww-browse-url)))

  ;; adna-mode: open wikilinks with eww when URL, else find-file
  (setq adna-browse-url-function #'eww-browse-url)

  ;; ── doom-modeline ────────────────────────────────────────────────────────
  ;; icon nil = text-only; inherits spacemacs-dark faces, no icon font required.
  ;; Custom adna-vault segment + spacelattice-main format deferred to P4 adna layer.
  (with-eval-after-load 'doom-modeline
    (setq doom-modeline-height 25
          doom-modeline-bar-width 4
          doom-modeline-icon nil
          doom-modeline-buffer-file-name-style 'truncate-with-project
          doom-modeline-minor-modes nil
          doom-modeline-enable-word-count nil
          doom-modeline-buffer-encoding nil
          doom-modeline-checker-simple-format t
          doom-modeline-vcs-max-length 16))

  ;; ── font size guard ──────────────────────────────────────────────────────
  ;; Belt-and-suspenders: ensures 15pt even if unicode-fonts/osx layer overrides
  ;; dotspacemacs-default-font after init. height 150 = 15pt in 1/10pt units.
  (set-face-attribute 'default nil :height 150)

  ;; ── centaur-tabs: hide system buffers ────────────────────────────────────
  ;; Only show real file/project buffers in the tab bar. *Messages*, *scratch*,
  ;; *Info*, etc. are accessible via SPC b but don't pollute the visual tab row.
  ;; Uses the designed API: excluded-prefixes list + hash invalidation.
  (with-eval-after-load 'centaur-tabs
    (add-to-list 'centaur-tabs-excluded-prefixes "*")
    (when (boundp 'centaur-tabs-hide-hash)
      (clrhash centaur-tabs-hide-hash))))

