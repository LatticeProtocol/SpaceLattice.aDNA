;;; .spacemacs --- Spacemacs.aDNA standard dotfile  -*- mode: emacs-lisp; lexical-binding: t -*-
;;
;; Rendered to <vault-root>/init.el by skill_deploy. Spacemacs finds it via
;; $SPACEMACSDIR=<vault-root> (written to shell profile by skill_install).
;; dotspacemacs-directory is then the vault root — use it for all vault-relative paths.
;;
;; Remaining placeholder: LOCAL_LAYER_LIST — empty by default.
;;
;; License: GPL-3.0 (matches upstream Spacemacs)
;; Vault: github.com/LatticeProtocol/Spacemacs.aDNA

(defun dotspacemacs/layers ()
  "Configuration layers declaration."
  (setq-default
   dotspacemacs-distribution 'spacemacs-latticeprotocol
   dotspacemacs-enable-lazy-installation 'unused
   dotspacemacs-ask-for-lazy-installation t
   dotspacemacs-configuration-layer-path (list (concat dotspacemacs-directory "what/local/"))
   dotspacemacs-configuration-layers
   '(
     ;; === editing & navigation ===
     auto-completion
     better-defaults
     helm
     (treemacs :variables treemacs-use-follow-mode t)
     git
     version-control
     ibuffer                                         ; grouped buffer list (C-x C-b)
     (tabs :variables tabs-group-by-project-name t) ; centaur-tabs — project-grouped tabs
     imenu-list                                      ; outline side panel (SPC b i)
     nav-flash                                       ; flash current line after navigation

     ;; === OS & fonts ===
     osx                                             ; macOS modifier keys + system integration
     unicode-fonts                                   ; color emoji + full Unicode coverage on macOS
     theming                                         ; per-theme face overrides via theming-modifications alist (ADR-021)

     ;; === languages ===
     (lsp :variables lsp-headerline-breadcrumb-enable t)
     (python :variables python-backend 'lsp python-fill-column 100)
     (typescript :variables typescript-backend 'lsp typescript-fmt-on-save t)
     (rust :variables rust-backend 'lsp rust-format-on-save t)
     (go :variables go-backend 'lsp go-format-before-save t)
     (javascript :variables javascript-backend 'lsp node-add-modules-path t)
     react                                           ; extends javascript layer
     shell-scripts
     emacs-lisp
     (markdown :variables markdown-live-preview-engine 'vmd)
     (org :variables org-want-todo-bindings t
                      org-enable-roam-support t
                      org-enable-roam-protocol t
                      org-enable-sticky-header t
                      org-enable-org-journal-support nil) ; journal style TBD per operator
     yaml
     csv
     toml
     graphviz                                        ; .dot file editing + live preview
     mermaid                                         ; .mmd diagrams (requires mermaid-cli)
     (latex :variables latex-build-command "LatexMk"
                       latex-backend 'lsp)           ; requires texlive + texlab LSP
     pdf                                             ; pdf-tools — native PDF rendering
     epub                                            ; nov.el — epub reader
     html                                            ; web-mode for HTML/Jinja/Django templates

     ;; === tools ===
     (shell :variables shell-default-shell 'vterm shell-default-position 'bottom)
     multiple-cursors
     spell-checking
     syntax-checking
     restclient                                      ; HTTP REPL via .http files (SPC m s s)
     docker                                          ; Dockerfile + docker-compose support
     kubernetes                                      ; k8s resource editing + kubectl integration
     ansible                                         ; YAML playbooks + vault + inventory navigation
     ipython-notebook                                ; ein — Jupyter notebooks in Emacs (§3.1 Python/DS)
     (dap :variables dap-python-debugger 'debugpy)  ; Debug Adapter Protocol — all language debuggers
     tree-sitter                                     ; Emacs 29+ treesit — structured syntax highlighting

     ;; === email ===
     (mu4e :variables mu4e-installation-path "/usr/local/share/emacs/site-lisp/mu4e"
                      mu4e-enable-async-operations t) ; requires: brew install mu + isync

     ;; === AI + agentic ===
     claude-code-ide                                 ; Claude Code MCP bridge — buffer/diagnostic/tree-sitter context (ADR-019)
     (llm-client :variables llm-client-enable-gptel t) ; gptel — Claude/OpenAI/Ollama from any buffer

     ;; === Spacemacs.aDNA bridge ===
     (adna :variables
           adna-claude-code-command "claude")  ; override path if claude not on $PATH

     ;; === operator-added local layers (dirs inside what/local/ via dotspacemacs-configuration-layer-path) ===
     {{LOCAL_LAYER_LIST}}
     )
   ;; Packages not in any layer:
   ;;   link-hint         — Vimium-style overlay on all visible links (SPC j o / SPC j O)
   ;;   ace-link          — 'o' in eww/info/help jumps to any visible link
   ;;   dwim-shell-command — OS-aware shell commands with context-aware I/O (§P3-12)
   dotspacemacs-additional-packages '(link-hint ace-link dwim-shell-command)
   dotspacemacs-frozen-packages '()
   dotspacemacs-excluded-packages '()
   dotspacemacs-install-packages 'used-only))

(defun dotspacemacs/init ()
  "Initialization. Called at very startup, before layers, packages, or user config."
  (setq-default
   dotspacemacs-elpa-https t
   dotspacemacs-elpa-timeout 5
   dotspacemacs-gc-cons '(200000000 0.1)
   dotspacemacs-read-process-output-max (* 4 1024 1024)
   dotspacemacs-check-for-update nil
   dotspacemacs-elpa-subdirectory 'emacs-version
   dotspacemacs-editing-style 'vim
   ;; Banner: official Spacemacs logo. Custom ASCII assets in what/standard/assets/
   ;; are available but deferred to P4 fork branding.
   dotspacemacs-startup-banner 'official
   dotspacemacs-startup-lists '((recents . 5) (projects . 7))
   dotspacemacs-startup-buffer-responsive t
   dotspacemacs-show-startup-list-numbers t
   ;; LP-branded themes (spacemacs-dark derivative with cooler bg + sharper accent).
   ;; Loaded from layers/+themes/latticeprotocol-theme/ local package (ADR-026).
   ;; spacemacs-dark included as fallback in case LP theme package fails to load (ADR-030).
   dotspacemacs-themes '(latticeprotocol-dark latticeprotocol-light spacemacs-dark)
   ;; doom-modeline: superior info density + aDNA vault segment.
   ;; Adapts to spacemacs-dark faces (icon nil = text-only, theme-agnostic).
   dotspacemacs-mode-line-theme 'doom
   dotspacemacs-colorize-cursor-according-to-state t
   dotspacemacs-default-font '("SpaceMono Nerd Font" :size 13.0 :weight normal :width normal) ; ADR-023
   dotspacemacs-default-icons-font 'nerd-icons                                                 ; ADR-023
   dotspacemacs-leader-key "SPC"
   dotspacemacs-emacs-command-key "SPC"
   dotspacemacs-ex-command-key ":"
   dotspacemacs-emacs-leader-key "M-m"
   dotspacemacs-major-mode-leader-key ","
   dotspacemacs-major-mode-emacs-leader-key "C-M-m"
   dotspacemacs-distinguish-gui-tab nil
   dotspacemacs-default-layout-name "Default"
   dotspacemacs-display-default-layout nil
   dotspacemacs-auto-resume-layouts nil
   dotspacemacs-auto-generate-layout-names nil
   dotspacemacs-large-file-size 1
   dotspacemacs-auto-save-file-location 'cache
   dotspacemacs-max-rollback-slots 5
   dotspacemacs-enable-paste-transient-state nil
   dotspacemacs-which-key-delay 0.4
   dotspacemacs-which-key-position 'bottom
   dotspacemacs-switch-to-buffer-prefers-purpose nil
   dotspacemacs-loading-progress-bar t
   dotspacemacs-fullscreen-at-startup nil
   dotspacemacs-fullscreen-use-non-native nil
   dotspacemacs-maximized-at-startup t
   dotspacemacs-undecorated-at-startup nil
   dotspacemacs-active-transparency 90
   dotspacemacs-inactive-transparency 90
   dotspacemacs-background-transparency 100          ; ADR-020: opaque bg — no bleed-through
   dotspacemacs-show-transient-state-title t
   dotspacemacs-show-transient-state-color-guide t
   dotspacemacs-mode-line-unicode-symbols t
   dotspacemacs-smooth-scrolling t
   dotspacemacs-line-numbers '(:relative t :enabled-for-modes prog-mode text-mode)
   dotspacemacs-folding-method 'evil
   dotspacemacs-smartparens-strict-mode nil
   dotspacemacs-smart-closing-parenthesis nil
   dotspacemacs-highlight-delimiters 'all
   dotspacemacs-enable-server t
   dotspacemacs-server-socket-dir nil
   dotspacemacs-persistent-server t
   dotspacemacs-search-tools '("rg" "ag" "grep")
   dotspacemacs-frame-title-format '("%b [" (:eval (projectile-project-name)) "]") ; buffer + project (ADR-022)
   dotspacemacs-icon-title-format nil
   dotspacemacs-show-trailing-whitespace t
   dotspacemacs-whitespace-cleanup 'trailing
   dotspacemacs-use-clean-aindent-mode t
   dotspacemacs-zone-out-when-idle nil
   dotspacemacs-pretty-docs nil
   dotspacemacs-home-shorten-agenda-source nil
   dotspacemacs-byte-compile nil))

(defun dotspacemacs/user-env ()
  "Setup environment variables."
  (spacemacs/load-spacemacs-env))

(defun dotspacemacs/user-init ()
  "Called before layer config. Sets pre-load preferences and pulls in operator-private elisp."
  ;; vterm: auto-compile the native module on first install (no interactive
  ;; prompt during batch boot). Required for skill_install to complete in
  ;; ref-clean envs where the module hasn't been compiled yet.
  (setq vterm-always-compile-module t)

  ;; exec-path-from-shell (§3.2 macOS workaround): inherit $PATH from login shell.
  ;; Suppresses "interactive shell" warning; ensures GUI-launched Emacs gets
  ;; the same PATH as a terminal session (homebrew, pyenv, rbenv, etc.).
  (when (and (eq system-type 'darwin) (fboundp 'exec-path-from-shell-initialize))
    (setq exec-path-from-shell-check-startup-files nil)
    (exec-path-from-shell-initialize))

  ;; native-comp (§3.2): silence async compilation warnings in Emacs 28+.
  ;; Avoids spurious *Warnings* popups during package install.
  (when (boundp 'native-comp-async-report-warnings-errors)
    (setq native-comp-async-report-warnings-errors 'silent))

  ;; native-comp eln cache (§3.6): explicit cache dir prevents cross-version
  ;; pollution when multiple Emacs builds coexist (homebrew + built-from-source).
  (when (boundp 'native-comp-eln-load-path)
    (add-to-list 'native-comp-eln-load-path
                 (expand-file-name "eln-cache/" user-emacs-directory)))

  ;; Load operator's private elisp last (gitignored) — additive only.
  (let ((private-el (expand-file-name "operator.private.el"
                                      (concat dotspacemacs-directory "what/local"))))
    (when (file-readable-p private-el)
      (load private-el nil 'nomessage))))

(defun dotspacemacs/user-load ()
  "Library to load when dumping. Empty for now.")

(defun dotspacemacs/user-config ()
  "Configuration. Called at end of startup, after layers loaded."
  ;; Changes in this function body: reload with SPC f e R (hot-reload, ~3s).
  ;; Changes in dotspacemacs/init, new layers, or new packages: SPC q r (full restart, ~20s).

  ;;; ── §P3-01 Dotfile structure / workspace anchor ─────────────────────────
  ;; Lattice workspace root — all finds, terminals, and projects anchor here.
  (cd (expand-file-name "~/lattice/"))

  ;;; ── §P3-02 dotspacemacs-* variables ─────────────────────────────────────
  ;; (populated by mission P3-02)

  ;;; ── §P3-03 adna layer / aDNA hooks ──────────────────────────────────────
  (when (fboundp 'adna/setup-global-hooks)
    (adna/setup-global-hooks))

  ;;; ── §P3-04 Themes / modeline / banner ───────────────────────────────────
  ;; doom-modeline: icon nil = text-only; inherits spacemacs-dark faces.
  ;; adna-vault segment + spacelattice-main format deferred to P4 adna layer.
  (with-eval-after-load 'doom-modeline
    (setq doom-modeline-height 25
          doom-modeline-bar-width 4
          doom-modeline-icon nil
          doom-modeline-buffer-file-name-style 'truncate-with-project
          doom-modeline-minor-modes nil
          doom-modeline-enable-word-count nil
          doom-modeline-buffer-encoding nil
          doom-modeline-checker-simple-format t
          doom-modeline-vcs-max-length 16))

  ;;; ── §P3-05 Editing / completion / packages ──────────────────────────────
  ;; centaur-tabs: hide system buffers — only real file/project buffers in tab bar.
  ;; *Messages*, *scratch*, *Info* etc. still accessible via SPC b.
  (with-eval-after-load 'centaur-tabs
    (add-to-list 'centaur-tabs-excluded-prefixes "*")
    (when (boundp 'centaur-tabs-hide-hash)
      (clrhash centaur-tabs-hide-hash)))

  ;;; ── §P3-06 Performance / evil / fonts ───────────────────────────────────
  ;; Belt-and-suspenders font guard: ensures 15pt even if unicode-fonts/osx layer
  ;; overrides dotspacemacs-default-font after init. height 150 = 15pt (1/10pt units).
  (set-face-attribute 'default nil :height 150)

  ;;; ── §P3-07 Workarounds / org-mode ───────────────────────────────────────

  ;; ─ LSP file-watcher limit ─────────────────────────────────────────────────
  ;; Disables FS-watchers that exhaust inotify on large monorepos (~/lattice/).
  ;; Pairs with ADR-016 GC/throughput tuning already in dotspacemacs/init.
  (with-eval-after-load 'lsp-mode
    (setq lsp-enable-file-watchers nil
          lsp-idle-delay 0.5
          lsp-completion-provider :capf
          ;; §3.4 LSP UI — diagnostics on modeline (workspace scope); doc at point.
          lsp-modeline-diagnostics-enable t
          lsp-modeline-diagnostics-scope :workspace
          lsp-ui-doc-position 'at-point
          lsp-ui-doc-delay 0.5))

  ;; ─ Org: double-load guard + full config ──────────────────────────────────
  ;; All org config is wrapped in with-eval-after-load to ensure the ELPA
  ;; org layer (not Emacs built-in org) is already active when these run.
  (with-eval-after-load 'org
    ;; Vault-local org dir: modular, self-contained context graph.
    ;; Lives at <vault-root>/org/ alongside missions, sessions, campaigns.
    (setq org-directory (concat dotspacemacs-directory "org/"))

    ;; Minimal agenda: inbox + work only.
    (setq org-agenda-files
          (list (concat dotspacemacs-directory "org/inbox.org")
                (concat dotspacemacs-directory "org/work.org")))

    ;; Refile any heading in agenda files, full depth.
    (setq org-refile-targets '((nil :maxlevel . 9)
                               (org-agenda-files :maxlevel . 9))
          org-refile-use-outline-path t
          org-outline-path-complete-in-steps nil)

    ;; TODO state machine.
    (setq org-todo-keywords
          '((sequence "TODO" "NEXT" "WAIT" "|" "DONE" "CANCELLED")))

    ;; Babel: python (ML), shell (runbooks/DevOps), jupyter (ein notebook kernels).
    (org-babel-do-load-languages
     'org-babel-load-languages
     '((emacs-lisp . t)
       (shell      . t)
       (python     . t)
       (jupyter    . t)))

    ;; Capture templates: inbox TODO, datetree session note, decision candidate, code snippet.
    (setq org-capture-templates
          '(("t" "TODO inbox" entry
             (file+headline "org/inbox.org" "Inbox")
             "* TODO %?\n  %i\n  %a\n  :CREATED: %U")
            ("s" "Session note" entry
             (file+olp+datetree "org/work.org")
             "* %<%H:%M> %?\n  %i")
            ("d" "Decision candidate" entry
             (file+headline "org/work.org" "Decisions")
             "* DECISION %?\n  Context: %i\n  Ref: %a\n  :CREATED: %U")
            ("c" "Code snippet" entry
             (file+headline "org/work.org" "Snippets")
             "* %?\n  #+BEGIN_SRC %^{Language}\n  %i\n  #+END_SRC\n  Ref: %a")))

    ;; Clock: persist across restarts; resume last clock; clean zero-time entries.
    (setq org-clock-persist t
          org-clock-in-resume t
          org-clock-out-remove-zero-time-clocks t
          org-clock-report-include-clocking-task t)
    (org-clock-persistence-insinuate))

  ;; Export backends: Markdown (built-in ox-md) — loaded lazily.
  (with-eval-after-load 'ox
    (require 'ox-md nil t))

  ;; ─ Org-roam v2 ────────────────────────────────────────────────────────────
  ;; Vault-local roam graph: DB sits alongside org files in <vault-root>/org/.
  ;; autosync-mode keeps the DB current without manual M-x org-roam-db-sync.
  (with-eval-after-load 'org-roam
    (setq org-roam-directory  (concat dotspacemacs-directory "org/")
          org-roam-db-location (concat dotspacemacs-directory "org/.roam.db"))
    (org-roam-db-autosync-mode))

  ;; ─ Helm stability knobs ───────────────────────────────────────────────────
  ;; Prevents accidental minibuffer dismissal; enables fuzzy matching globally.
  (with-eval-after-load 'helm
    (setq helm-prevent-escaping-from-minibuffer t
          helm-buffers-fuzzy-matching t
          helm-M-x-fuzzy-match t
          helm-imenu-fuzzy-match t))

  ;; ─ Treemacs auto-load regression note ────────────────────────────────────
  ;; If a MELPA treemacs update causes workspace corruption, pin via:
  ;;   (dotspacemacs-additional-packages '((treemacs :location (recipe :fetcher github
  ;;     :repo "Alexander-Miller/treemacs" :commit "<known-good-sha>"))))
  ;; Current MELPA version is stable; no pin needed at P3-07 close.

  ;;; ── §P3-08 Languages / keys / navigation ────────────────────────────────
  ;; Project-search: ripgrep; discover all vaults in ~/lattice/
  (with-eval-after-load 'projectile
    (setq projectile-generic-command "rg --files --hidden --glob '!.git/'")
    (setq projectile-project-search-path (list (expand-file-name "~/lattice/")))
    (projectile-discover-projects-in-search-path))

  ;; treemacs: ~/lattice/ workspace
  (with-eval-after-load 'treemacs
    (let ((lattice (expand-file-name "~/lattice")))
      (when (and (file-directory-p lattice)
                 (fboundp 'treemacs-add-project-to-workspace))
        (treemacs-add-project-to-workspace lattice "Lattice"))))

  (with-eval-after-load 'magit
    (setq magit-refresh-status-buffer nil))

  ;; avy-goto-char-timer: snappier than default 0.5s
  (with-eval-after-load 'avy
    (setq avy-timeout-seconds 0.3))
  (spacemacs/set-leader-keys "jJ" #'avy-goto-char-timer)

  ;; link-hint: Vimium-style overlay on all visible links
  (with-eval-after-load 'link-hint
    (spacemacs/set-leader-keys "jo" #'link-hint-open-link)
    (spacemacs/set-leader-keys "jO" #'link-hint-copy-link))

  ;; Startup timing log (§3.6): prints elapsed time + GC count to *Messages*.
  (add-hook 'emacs-startup-hook
            (lambda ()
              (message "Spacemacs ready in %.2fs (%d GCs)"
                       (float-time (time-subtract after-init-time before-init-time))
                       gcs-done)))

  ;;; ── §P3-09 Obsidian plugin audit ─────────────────────────────────────────
  ;; (populated by mission P3-09)

  ;;; ── §P3-10 Layer expansion audit ─────────────────────────────────────────
  ;; (populated by mission P3-10)

  ;;; ── §P3-11 Browser / eww integration ────────────────────────────────────
  ;; Spacemacs.aDNA browser stack: eww → xwidget (--with-xwidgets) → external
  (with-eval-after-load 'eww
    (when (fboundp 'ace-link-eww)
      (define-key eww-mode-map (kbd "o") #'ace-link-eww))
    (define-key eww-mode-map (kbd "v") #'eww-open-in-new-buffer))

  (setq browse-url-browser-function
        '((".*claude\\.ai.*"            . browse-url-default-browser)
          (".*atlassian\\.net.*"        . browse-url-default-browser)
          (".*slack\\.com.*"            . browse-url-default-browser)
          (".*"                         . eww-browse-url)))

  (setq adna-browse-url-function #'eww-browse-url)

  ;;; ── §P3-12 macOS platform integration ───────────────────────────────────
  ;; See what/context/platform_macos.md for full context and rationale.
  ;; (populated by mission p3_12_platform_context_macos — operator approval required)
  (when (eq system-type 'darwin)
    ;; Command → Meta; Option → macOS (diacritics, special chars pass through)
    (setq mac-command-modifier 'meta
          mac-option-modifier 'none)
    ;; Reuse existing frame rather than popping new ones from 'open' CLI
    (setq ns-pop-up-frames nil)
    ;; Transparent title bar; dark appearance to match spacemacs-dark theme
    (add-to-list 'default-frame-alist '(ns-transparent-titlebar . t))
    (add-to-list 'default-frame-alist '(ns-appearance . dark))
    ;; Accurate color rendering for themes
    (setq ns-use-srgb-colorspace nil))

  ;; dwim-shell-command — macOS-aware shell commands on buffer/dired selection
  ;; Package in additional-packages (§P3-12). Remaps shell-command and dired
  ;; async-shell-command to context-aware variants.
  (with-eval-after-load 'dwim-shell-command
    (define-key global-map [remap shell-command] #'dwim-shell-command)
    (define-key dired-mode-map
      [remap dired-do-async-shell-command] #'dwim-shell-command)
    (define-key dired-mode-map
      [remap dired-do-shell-command] #'dwim-shell-command)
    (define-key dired-mode-map
      [remap dired-smart-shell-command] #'dwim-shell-command))

  ;;; ── §P3-13 Performance and editing hardening (ADR-018) ───────────────────
  ;; Bidi suppression — major speedup for large files (JSON/logs/generated code).
  ;; Only left-to-right text is used in this vault and typical ML codebases.
  (setq-default bidi-display-reordering 'left-to-right
                bidi-paragraph-direction 'left-to-right)
  (setq bidi-inhibit-bpa t)

  ;; Skip syntax highlighting during rapid typing — eliminates micro-stutter
  ;; in large buffers and tree-sitter modes.
  (setq redisplay-skip-fontification-on-input t)

  ;; Prevent ffap from pinging hostnames — avoids multi-second freezes when
  ;; point is on a hostname-like string.
  (setq ffap-machine-p-known 'reject)

  ;; Hide cursors in non-focused windows — reduces rendering work.
  (setq-default cursor-in-non-selected-windows nil)
  (setq highlight-nonselected-windows nil)

  ;; Preserve external clipboard content before kill-ring operations.
  (setq save-interprogram-paste-before-kill t)

  ;; Deduplicate kill ring entries.
  (setq kill-do-not-save-duplicates t)

  ;; Auto-chmod: make script files (shebang lines) executable on save.
  (add-hook 'after-save-hook #'executable-make-buffer-file-executable-if-script-p)

  ;; Proportional window resizing when splitting.
  (setq window-combination-resize t)

  ;; winner-mode: reversible window configurations (C-x 1 becomes toggleable).
  (winner-mode +1)

  ;; Mark ring: continue popping with C-SPC after first C-u C-SPC.
  (setq set-mark-command-repeat-pop t)

  ;; Auto-focus help windows (C-h f, C-h v jump to help buffer).
  (setq help-window-select t)

  ;; re-builder: eliminate double-escaping in interactive regex development.
  (setq reb-re-syntax 'string)

  ;;; ── §P5-01 Agentic layout on startup (opt-in) ───────────────────────────
  ;; Uncomment in what/local/operator.private.el to activate at boot:
  ;; (add-hook 'emacs-startup-hook #'adna/layout-agentic-default)
  )

;; Do not write anything past this comment. Anything written here is overwritten
;; by Emacs on save. Operator customizations belong in
;; what/local/operator.private.el (loaded by dotspacemacs/user-init above).
(defun dotspacemacs/emacs-custom-settings ()
  "Emacs custom settings. Auto-managed by Spacemacs.")

;; Local Variables:
;; no-byte-compile: t
;; End:
