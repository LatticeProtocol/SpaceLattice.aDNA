;;; .spacemacs --- SpaceLattice.aDNA standard dotfile  -*- mode: emacs-lisp; lexical-binding: t -*-
;;
;; Template rendered to ~/.spacemacs by skill_deploy (how/standard/skills/skill_deploy.md).
;; Placeholders use {{NAME}} syntax — substituted from what/standard/layers.md +
;; what/local/operator.private.el (if present).
