# THIS IS AN EXAMPLE TEMPLATE.
# Copy to secrets.env (without .example), then edit. The real file is gitignored.
#
# Loaded by dotspacemacs/user-init into Emacs `process-environment` if present.
# Format: standard shell env (KEY=value, # for comments).

# === Anthropic / Claude API ===
# Used by Claude Code (`SPC c c`) which inherits the Emacs environment.
# Standard Claude Code config in ~/.claude/settings.json takes precedence — set this
# only if you want a different key for the Spacemacs-spawned Claude Code session
# than your global default.
# ANTHROPIC_API_KEY=sk-ant-...

# === Local llama.cpp / Ollama ===
# OLLAMA_HOST=http://localhost:11434
# LLAMA_CPP_HOST=http://localhost:8080

# === Other (operator's choice) ===
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=...

# === Obsidian Advanced URI vault name ===
# If your Obsidian vault name differs from the directory name (rare), override:
# ADNA_OBSIDIAN_VAULT_OVERRIDE=my-vault

# === GitHub for skill_publish_lattice (Phase 7) ===
# GITHUB_TOKEN=ghp_...   # only needed for Phase 7 publish to LatticeProtocol/SpaceLattice.aDNA

# Reminder: this file is gitignored. NEVER commit a real secrets.env.
# `git ls-files | grep secrets.env` MUST return empty (verified by skill_health_check).
