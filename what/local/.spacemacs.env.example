# .spacemacs.env — operator-private environment variables for SpaceLattice.aDNA
#
# Copy this file to <vault-root>/.spacemacs.env and fill in your values.
# skill_deploy renders the dotfile to <vault-root>/init.el and sets
# SPACEMACSDIR=<vault-root>, so spacemacs/load-spacemacs-env loads THIS file.
#
# gitignored — never committed to vault history.
#
# Syntax: KEY=value (no export needed; Spacemacs loads these via setenv).

# ── Deployment identity ────────────────────────────────────────────────────
# Set by skill_install; here for documentation + manual override if needed.
SPACEMACSDIR=/Users/<username>/lattice/SpaceLattice.aDNA

# ── Shell PATH for GUI Emacs ───────────────────────────────────────────────
# GUI Emacs does not inherit shell PATH on macOS. Add entries as needed.
# exec-path-from-shell (in user-env) will copy these if configured.
PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin

# ── Lattice Protocol CLI ───────────────────────────────────────────────────
# LATLAB_API_KEY=<your-latlab-api-key>
# LATLAB_HOME=/Users/<username>/lattice/latlab

# ── Python / ML tooling ───────────────────────────────────────────────────
# PYENV_ROOT=/Users/<username>/.pyenv
# VIRTUAL_ENV=/Users/<username>/lattice/.venv

# ── Claude Code / Anthropic ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=<your-key>

# ── Obsidian vault path (for adna wikilink resolver) ──────────────────────
# ADNA_OBSIDIAN_VAULT=/Users/<username>/lattice
