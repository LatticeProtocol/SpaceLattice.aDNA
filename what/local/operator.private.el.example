;; Override standard theme:
;; (setq-default dotspacemacs-themes '(doom-one doom-solarized-dark))

;;; ============================================================================
;;; PERSONAL LAYERS
;;; ============================================================================

;; Add layers without touching standard. They get appended in dotspacemacs/layers
;; via the {{LOCAL_LAYER_LIST}} placeholder.
;;
;; Examples:
;; - org-roam, org-noter for note-taking
;; - chatgpt-shell or gptel for in-Emacs LLM calls
;; - vundo for visual undo tree

;;; ============================================================================
;;; aDNA LAYER PREFERENCES
;;; ============================================================================

;; Enable Obsidian round-trip (off by default per obsidian-coupling.md):
;; (setq adna-obsidian-roundtrip-enabled t)

;; Prefer local LLM over Claude API for in-Emacs calls:
;; (setq adna-prefer-local t)

;; Log every in-Emacs LLM call to *Messages*:
;; (setq adna-log-llm-calls t)

;;; ============================================================================
;;; CLAUDE CODE INTEGRATION
;;; ============================================================================

;; Override the model for SPC c c sessions (otherwise Claude Code's default):
;; (setq adna-claude-code-model "claude-opus-4-7")

